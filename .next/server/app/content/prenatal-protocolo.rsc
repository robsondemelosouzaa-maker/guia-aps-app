"$L4",null,{}],["$","div",null,{"className":"bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 px-5 py-4 rounded-2xl","children":["$","p",null,{"className":"text-sm font-semibold text-slate-700 dark:text-slate-300 leading-relaxed","children":"O pré-natal de baixo risco pode ser realizado pelo enfermeiro na APS. Prevê mínimo de 6 consultas (preferencialmente 8) distribuídas ao longo da gestação. O enfermeiro realiza consultas intercaladas com o médico."}]}],["$","div",null,{"className":"prose-sm max-w-none space-y-3","children":[["$","p","0",{"className":"text-sm text-slate-600 dark:text-slate-400 font-medium leading-relaxed","dangerouslySetInnerHTML":{"__html":"A consulta de enfermagem no pré-natal é prevista em lei (Lei 7.498/1986 e Resolução COFEN 736/2024). O enfermeiro realiza consultas, solicita exames de rotina e refer encaminha quando identifica risco."}}],["$","h2","1",{"className":"text-lg font-black mt-6 mb-2","children":"Número mínimo de consultas:"}],["$","p","2",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• Até 28 semanas: mensais"}],["$","p","3",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• De 28 a 36 semanas: quinzenais"}],["$","p","4",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• A partir de 36 semanas: semanais"}],["$","h2","5",{"className":"text-lg font-black mt-6 mb-2","children":"Ações por consulta:"}],["$","p","6",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"1. Verificar pressão arterial e peso"}],["$","p","7",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"2. Medir altura uterina"}],["$","p","8",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"3. Verificar batimentos cardíacos fetais (BCF)"}],["$","p","9",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"4. Avaliar edema"}],["$","p","10",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"5. Solicitar/revisar exames de rotina"}],["$","p","11",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"6. Orientar sinais de alerta"}],["$","h2","12",{"className":"text-lg font-black mt-6 mb-2","children":"Sinais de alerta (encaminhar imediatamente):"}],["$","p","13",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• PA ≥ 140/90 mmHg"}],["$","p","14",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• Cefaleia intensa, visão turva, epigastralgia"}],["$","p","15",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• Ausência de movimentos fetais"}],["$","p","16",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• Sangramento vaginal"}],["$","p","17",{"className":"pl-4 text-sm text-slate-600 dark:text-slate-400 font-medium","children":"• Febre"}]]}],["$","section",null,{"className":"space-y-3","children":[["$","h2",null,{"className":"text-lg font-black flex items-center gap-2","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":20,"height":20,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-check-square text-emerald-500","children":[["$","path","1pflzl",{"d":"m9 11 3 3L22 4"}],["$","path","1jnkn4",{"d":"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"}],"$undefined"]}]," Checklist da Consulta"]}],["$","div",null,{"className":"space-y-2","children":[["$","div","0",{"className":"flex items-start gap-3 bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 px-4 py-3 rounded-xl","children":[["$","div",null,{"className":"w-5 h-5 rounded-md border-2 border-slate-200 dark:border-slate-700 shrink-0 mt-0.5 